# ---- Discord bot ----

APP_ID="your app ID"

# Optional. When set: deploy-commands.js registers slash commands in this guild only (instant, good for dev).
# When unset: commands are registered globally (all servers where the bot is invited; may take up to 1 hour to propagate).
SERVER_ID="your server ID"

#Discord Bot Token
DISCORD_TOKEN="your bot's token"

# ---- STT wrapper (faster-whisper) ----

# Model to load. One of:
#   • Built-in size: tiny, base, small, medium, large-v3, turbo, etc. (see https://github.com/SYSTRAN/faster-whisper or faster_whisper.utils.available_models())
#   • Hugging Face repo id: owner/repo (e.g. Systran/faster-whisper-medium, dwhoelz/whisper-medium-pt-ct2)
#   • Local path: absolute or relative path to a directory containing CTranslate2 model files (config.json, model.bin, tokenizer.json, etc.)
STT_MODEL_ID="dwhoelz/whisper-medium-pt-ct2"

# Where to download/cache models when using a size or HF repo. Ignored when STT_MODEL_ID is a local path. First run may download; set STT_USE_LOCAL=true to use cache only.
STT_DOWNLOAD_PATH=".models/"

# Use only cached models (no network). Set to true after first download, or for offline runs. Accepted: true (case-insensitive).
STT_USE_LOCAL=false

# Device for inference: cpu, cuda, or auto.
STT_DEVICE=auto

# Timeout for STT calls in milliseconds.
STT_TIMEOUT_MS=5000

# Optional: language hint for transcription (e.g. pt, en). Same codes as Whisper: https://github.com/openai/whisper#available-models-and-languages
# STT_LANGUAGE=pt

# Base URL used by the STT wrapper FastAPI server. Default is "http://localhost:8000".
STT_BASE_URL=http://localhost:8000

# ---- Worker ----

# Use the transcript worker in-process. Set 'false' to use the HTTP server. Default is true.
WORKER_USE_LOCAL=true

# Base URL used by the transcript worker Express http server when WORKER_USE_LOCAL is false. Default is "http://localhost:3000".
WORKER_BASE_URL=http://localhost:3000

# Port used by the transcript worker Express http server when WORKER_USE_LOCAL is false. Default is 3000.
WORKER_PORT=3000

# ---- LLM / summarization ----
# Whether to use a local LLM instead of a remote API. Reserved for future providers.
LLM_USE_LOCAL=true

# Which LLM provider the summarizer should call.
# For now only "ollama" is supported.
LLM_PROVIDER=ollama

# Timeout for LLM calls in milliseconds.
LLM_TIMEOUT_MS=20000

# Truncation controls for long meeting reports.
# Set to "true" to enable truncation before calling the LLM.
LLM_TRUNCATION_ENABLED=true

# Maximum number of characters from the report to send in each LLM call.
# For phi3:mini, 10000–12000 is a safe range; start with 12000.
LLM_TRUNCATION_MAX_CHARS=12000

# Strategy when truncating:
#   tail  -> most recent part of the meeting
#   head  -> começo da reunião
LLM_TRUNCATION_STRATEGY=tail

# Optional custom system prompt for the non-truncated path.
# If empty, a default PT-BR summarization prompt is used.
LLM_SYSTEM_PROMPT=

# Temperature passed to the LLM (0.0 = determinístico, maior = mais criativo).
LLM_TEMPERATURE=0.7

# Base URL of the Ollama server.
# Default when running locally:
#   ollama serve  ->  http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Name of the model to use with Ollama.
# phi3:mini has a ~4k token context window and is a good default.
OLLAMA_MODEL=phi3:mini